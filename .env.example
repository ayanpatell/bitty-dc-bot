# Server
PORT=3000
NODE_ENV=development

# Logging
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Telnyx
# Your Ed25519 public key — found in Mission Control → Keys & Credentials
# This is NOT your API key. It is the signing public key used to verify inbound webhooks.
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Discord
# The full webhook URL from your Discord channel's Integration settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Allowlist
# Comma-separated list of E.164 phone numbers allowed to forward messages
# Example: +14155551234,+12125559876
# Leave empty or omit to block all senders (safe default)
ALLOWED_FROM_NUMBERS=+14155551234
